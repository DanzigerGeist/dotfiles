{{- $destPath := joinPath .chezmoi.homeDir ".config/opencode/opencode.json" -}}
{{- $existing := dict -}}
{{- if (stat $destPath) -}}
  {{- $raw := output "cat" $destPath -}}
  {{- if ne (trim $raw) "" -}}
    {{- $existing = mustFromJson $raw -}}
  {{- end -}}
{{- end -}}
{{- $yarrlAtlassianURL := trim (gopass "yarrl/atlassian/url") -}}
{{- $yarrlAtlassianUser := trim (gopass "yarrl/atlassian/user") -}}
{{- $yarrlAtlassianToken := trim (gopass "yarrl/atlassian/token") -}}
{{- $miratechAtlassianURL := trim (gopass "miratech/atlassian/url") -}}
{{- $miratechAtlassianUser := trim (gopass "miratech/atlassian/user") -}}
{{- $miratechAtlassianToken := trim (gopass "miratech/atlassian/token") -}}
{{- $discogsToken := trim (gopass "personal/discogs/token") -}}
{{- $homebrewBinDir := "/opt/homebrew/bin" -}}
{{- $voltaBinDir := joinPath .chezmoi.homeDir ".volta/bin" -}}
{{- $mcpAtlassianPath := joinPath $homebrewBinDir "mcp-atlassian" -}}
{{- $context7McpPath := joinPath $homebrewBinDir "context7-mcp" -}}
{{- $githubMcpPath := joinPath $homebrewBinDir "github-mcp-server" -}}
{{- $imcpWrapperPath := joinPath .chezmoi.homeDir ".config/opencode/bin/imcp-opencode" -}}
{{- $npxPath := joinPath $voltaBinDir "npx" -}}
{{- $playwrightMcpPath := joinPath $homebrewBinDir "playwright-mcp" -}}
{{- $snykPath := joinPath $homebrewBinDir "snyk" -}}
{{- $terraformMcpPath := joinPath $homebrewBinDir "terraform-mcp-server" -}}
{{- $uvxPath := joinPath $homebrewBinDir "uvx" -}}
{{- $workiqPath := joinPath $voltaBinDir "workiq" -}}

{{- $mcp := dict
  "Atlassian (Miratech)" (dict
    "type" "local"
    "command" (list
      $mcpAtlassianPath
      "--transport" "stdio"
      "--jira-url" $miratechAtlassianURL
      "--jira-username" $miratechAtlassianUser
      "--jira-token" $miratechAtlassianToken
      "--confluence-url" (printf "%s/wiki" $miratechAtlassianURL)
      "--confluence-username" $miratechAtlassianUser
      "--confluence-token" $miratechAtlassianToken
      "--toolsets=all"
    )
  )
  "Atlassian (Yarrl)" (dict
    "type" "local"
    "command" (list
      $mcpAtlassianPath
      "--transport" "stdio"
      "--jira-url" $yarrlAtlassianURL
      "--jira-username" $yarrlAtlassianUser
      "--jira-token" $yarrlAtlassianToken
      "--confluence-url" (printf "%s/wiki" $yarrlAtlassianURL)
      "--confluence-username" $yarrlAtlassianUser
      "--confluence-token" $yarrlAtlassianToken
      "--toolsets=all"
    )
  )
  "Discogs" (dict
    "type" "local"
    "command" (list $npxPath "-y" "discogs-mcp-server")
    "environment" (dict
      "DISCOGS_PERSONAL_ACCESS_TOKEN" $discogsToken
    )
  )
  "Context7" (dict
    "type" "local"
    "command" (list $context7McpPath)
    "environment" (dict
      "CONTEXT7_API_KEY" (trim (gopass "personal/context7/token"))
    )
  )
  "GitHub" (dict
    "type" "local"
    "command" (list $githubMcpPath "stdio" "--toolsets=all")
    "environment" (dict
      "GITHUB_PERSONAL_ACCESS_TOKEN" (trim (gopass "personal/github/tokens/personal"))
    )
  )
  "GitHub Grep" (dict
    "type" "local"
    "command" (list $uvxPath "grep-mcp")
  )
  "iMCP" (dict
    "type" "local"
    "command" (list $imcpWrapperPath)
  )
  "Packages" (dict
    "type" "local"
    "command" (list $npxPath "-y" "package-registry-mcp")
  )
  "Playwright" (dict
    "type" "local"
    "command" (list $playwrightMcpPath "--browser=webkit" "--isolated")
  )
  "Snyk" (dict
    "type" "local"
    "command" (list $snykPath "mcp" "-t" "stdio")
  )
  "Terraform" (dict
    "type" "local"
    "command" (list $terraformMcpPath "stdio")
  )
  "Web Search" (dict
    "type" "local"
    "command" (list $npxPath "-y" "exa-mcp-server")
  )
  "WorkIQ (Yarrl)" (dict
    "type" "local"
    "command" (list $workiqPath "mcp")
  )
-}}

{{- $_ := unset $existing "keybinds" -}}
{{- $_ := set $existing "$schema" "https://opencode.ai/config.json" -}}
{{- $_ := set $existing "plugin" (list "oh-my-opencode@latest" "@franlol/opencode-md-table-formatter@0.0.3" "opencode-wakatime") -}}
{{- $_ := set $existing "mcp" $mcp -}}
{{ mustToPrettyJson $existing }}
