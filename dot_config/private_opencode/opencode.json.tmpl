{{- $destPath := joinPath .chezmoi.homeDir ".config/opencode/opencode.json" -}}
{{- $existing := dict -}}
{{- if (stat $destPath) -}}
  {{- $raw := output "cat" $destPath -}}
  {{- if ne (trim $raw) "" -}}
    {{- $existing = mustFromJson $raw -}}
  {{- end -}}
{{- end -}}
{{- $yarrlAtlassianURL := trim (gopass "yarrl/atlassian/url") -}}
{{- $yarrlAtlassianUser := trim (gopass "yarrl/atlassian/user") -}}
{{- $yarrlAtlassianToken := trim (gopass "yarrl/atlassian/token") -}}
{{- $miratechAtlassianURL := trim (gopass "miratech/atlassian/url") -}}
{{- $miratechAtlassianUser := trim (gopass "miratech/atlassian/user") -}}
{{- $miratechAtlassianToken := trim (gopass "miratech/atlassian/token") -}}
{{- $discogsToken := trim (gopass "personal/discogs/token") -}}

{{- $mcp := dict
  "Atlassian (Miratech)" (dict
    "type" "local"
    "command" (list
      "/opt/homebrew/bin/mcp-atlassian"
      "--transport" "stdio"
      "--jira-url" $miratechAtlassianURL
      "--jira-username" $miratechAtlassianUser
      "--jira-token" $miratechAtlassianToken
      "--confluence-url" (printf "%s/wiki" $miratechAtlassianURL)
      "--confluence-username" $miratechAtlassianUser
      "--confluence-token" $miratechAtlassianToken
      "--toolsets=all"
    )
  )
  "Atlassian (Yarrl)" (dict
    "type" "local"
    "command" (list
      "/opt/homebrew/bin/mcp-atlassian"
      "--transport" "stdio"
      "--jira-url" $yarrlAtlassianURL
      "--jira-username" $yarrlAtlassianUser
      "--jira-token" $yarrlAtlassianToken
      "--confluence-url" (printf "%s/wiki" $yarrlAtlassianURL)
      "--confluence-username" $yarrlAtlassianUser
      "--confluence-token" $yarrlAtlassianToken
      "--toolsets=all"
    )
  )
  "Discogs" (dict
    "type" "local"
    "command" (list "npx" "-y" "discogs-mcp-server")
    "environment" (dict
      "DISCOGS_PERSONAL_ACCESS_TOKEN" $discogsToken
    )
  )
  "Context7" (dict
    "type" "local"
    "command" (list "context7-mcp")
    "environment" (dict
      "CONTEXT7_API_KEY" (trim (gopass "personal/context7/token"))
    )
  )
  "GitHub" (dict
    "type" "local"
    "command" (list "github-mcp-server" "stdio" "--toolsets=all")
    "environment" (dict
      "GITHUB_PERSONAL_ACCESS_TOKEN" (trim (gopass "personal/github/tokens/personal"))
    )
  )
  "iMCP" (dict
    "type" "local"
    "command" (list "/Applications/iMCP.app/Contents/MacOS/imcp-server")
  )
  "Packages" (dict
    "type" "local"
    "command" (list "npx" "-y" "package-registry-mcp")
  )
  "Playwright" (dict
    "type" "local"
    "command" (list "playwright-mcp" "--browser=webkit" "--isolated")
  )
  "Snyk" (dict
    "type" "local"
    "command" (list "snyk" "mcp" "-t" "stdio")
  )
  "Terraform" (dict
    "type" "local"
    "command" (list "terraform-mcp-server" "stdio")
  )
  "Web Search" (dict
    "type" "local"
    "command" (list "npx" "-y" "exa-mcp-server")
  )
  "WorkIQ (Yarrl)" (dict
    "type" "local"
    "command" (list "/Users/aleksy/.volta/bin/workiq" "mcp")
  )
-}}

{{- $_ := unset $existing "keybinds" -}}
{{- $_ := set $existing "$schema" "https://opencode.ai/config.json" -}}
{{- $_ := set $existing "plugin" (list "oh-my-opencode@latest" "@franlol/opencode-md-table-formatter@0.0.3" "opencode-wakatime") -}}
{{- $_ := set $existing "mcp" $mcp -}}
{{ mustToPrettyJson $existing }}
